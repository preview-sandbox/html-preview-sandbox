{
  "name": "html-preview-sandbox",
  "version": "0.1.0",
  "description": "A sandboxed preview pipeline for untrusted HTML.",
  "type": "module",
  "license": "MIT",
  "author": "html-preview-sandbox contributors",
  "homepage": "https://github.com/html-preview-sandbox/html-preview-sandbox#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/html-preview-sandbox/html-preview-sandbox.git"
  },
  "bugs": {
    "url": "https://github.com/html-preview-sandbox/html-preview-sandbox/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.browser.js",
      "default": "./dist/index.browser.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "THREAT_MODEL.md",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "npm run build && node --test test/*.test.js",
    "test:browser": "npm run build && playwright test",
    "pack:dry": "npm pack --dry-run",
    "audit": "npm_config_cache=.npm-cache npm_config_logs_dir=.npm-cache/_logs npm audit --omit=optional",
    "check:types": "tsc -p tsconfig.check.json",
    "check": "npm run check:types && npm test",
    "serve": "node scripts/serve.mjs"
  },
  "keywords": [
    "html",
    "preview",
    "sandbox",
    "iframe",
    "csp",
    "security",
    "untrusted-html",
    "ai-generated-html"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "jsdom": "^29.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
